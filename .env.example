# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Langfuse Observability (Optional)
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# App Settings
MAX_RESUME_SIZE_MB=10
MAX_RESUMES_PER_BATCH=50
CONFIDENCE_THRESHOLD=0.6
MAX_SCORER_RETRIES=2

# Semantic Embedding Settings (BGE — BAAI/bge-small-en-v1.5)
# Cosine similarity threshold for skill matching (0.0-1.0, default 0.72)
# Lower = more permissive matches, Higher = stricter
SKILL_SEMANTIC_THRESHOLD=0.72


# LinkedIn Profile Fetcher (Free — uses linkedin-api Python library)
# Uses your own LinkedIn account credentials to fetch any public profile.
# Tip: create a secondary LinkedIn account to avoid rate-limit concerns.
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Optional: Langfuse LLM Observability
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
